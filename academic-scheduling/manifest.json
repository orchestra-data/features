  "install_steps": [
    {
      "order": 1,
      "name": "Run database migrations",
      "type": "migration",
      "command": "npm run migrate:dev",
      "rollback_command": "# Manual: revert migrations in reverse order",
      "validate_command": "PGPASSWORD=postgres psql -h localhost -U postgres -d dev -c \"\\dt\" | grep -c \"class_instance_component_schedule\"",
      "blocking": true
    },
    {
      "order": 2,
      "name": "Copy backend endpoints",
      "type": "copy-endpoints",
      "command": "# Handled by feature-install.sh — copies 39 endpoint files",
      "rollback_command": "# Handled by feature-install.sh --rollback",
      "validate_command": "ls apps/api/src/endpoints/ | grep -ci \"academicyear\"",
      "blocking": true
    },
    {
      "order": 3,
      "name": "Copy type definitions",
      "type": "copy-types",
      "command": "# Handled by feature-install.sh",
      "rollback_command": "# Handled by feature-install.sh --rollback",
      "validate_command": "npm --workspace @cogedu/ava-api-types run build && npm --workspace @cogedu/ava-database-types run build",
      "blocking": true
    },
    {
      "order": 4,
      "name": "Copy frontend files",
      "type": "copy-frontend",
      "command": "# Handled by feature-install.sh — copies to apps/web/src/features/academic-scheduling/",
      "rollback_command": "rm -rf apps/web/src/features/academic-scheduling",
      "validate_command": "ls apps/web/src/features/academic-scheduling/",
      "blocking": true
    },
    {
      "order": 5,
      "name": "Register route in router.tsx",
      "type": "register-route",
      "command": "# Handled by feature-install.sh — patches router.tsx",
      "rollback_command": "# Restore router.tsx from .bak file",
      "validate_command": "grep \"academic-scheduling\" apps/web/src/router.tsx",
      "blocking": true
    },
    {
      "order": 6,
      "name": "Install npm dependencies",
      "type": "install-deps",
      "command": "npm install react-router-dom lucide-react sonner @fullcalendar/react @fullcalendar/daygrid @fullcalendar/timegrid @fullcalendar/interaction @fullcalendar/core @tanstack/react-query",
      "rollback_command": "npm uninstall react-router-dom lucide-react sonner @fullcalendar/react @fullcalendar/daygrid @fullcalendar/timegrid @fullcalendar/interaction @fullcalendar/core @tanstack/react-query",
      "validate_command": "npm ls react-router-dom 2>/dev/null",
      "blocking": false
    },
    {
      "order": 7,
      "name": "Build and validate",
      "type": "build-check",
      "command": "npm --workspace @cogedu/ava-api-types run build && npm --workspace @cogedu/ava-database-types run build && npm --workspace @cogedu/event-types run build && cd apps/web && npx tsc --noEmit",
      "rollback_command": "# Nothing to rollback",
      "validate_command": "cd apps/web && npx tsc --noEmit 2>&1 | grep -c \"error\" | grep \"^0$\"",
      "blocking": true
    }
  ],
  "route_registration": {
    "file": "apps/web/src/router.tsx",
    "imports_to_add": [
      "const academicSchedulingModule = lazy(() => import('@/features/academic-scheduling'))"
    ],
    "route_block": "          { path: 'academic-scheduling', element: <Suspense fallback={<div>Loading...</div>}><AcademicSchedulingModule /></Suspense> },",
    "insert_after": "// FEATURE_ROUTES_ANCHOR"
  },
  "dependencies": {
    "npm_install": [
      "react-router-dom",
