  "troubleshooting": [
    {
      "symptom": "TypeError: Cannot read properties of undefined (reading 'map')",
      "cause": "API returns empty array or null instead of expected data structure",
      "fix": "Check that seed data exists. Run: PGPASSWORD=postgres psql -h localhost -U postgres -d dev -c \"SELECT count(*) FROM company_event\""
    },
    {
      "symptom": "column \"start_date\" does not exist",
      "cause": "Wrong column name — the actual column is start_datetime (timestamptz)",
      "fix": "Replace start_date with start_datetime in all queries"
    },
    {
      "symptom": "401 Unauthorized on API calls",
      "cause": "Keycloak token not configured or expired",
      "fix": "Set DEV_AUTO_AUTH=1 in .env for development, or get token: curl -X POST http://localhost:8080/realms/cogedu/protocol/openid-connect/token -d \"client_id=web&grant_type=password&username=admin&password=admin\""
    },
    {
      "symptom": "Module not found: @fullcalendar/*",
      "cause": "FullCalendar packages not installed",
      "fix": "Run: npm install @fullcalendar/react @fullcalendar/daygrid @fullcalendar/timegrid @fullcalendar/interaction @fullcalendar/core"
    },
    {
      "symptom": "Route not rendering / blank page",
      "cause": "Feature route not registered in router.tsx",
      "fix": "Check that router.tsx contains a route for the feature slug. The install script should have added it automatically."
    },
    {
      "symptom": "npm run build fails with TS errors",
      "cause": "Type packages not built before web build",
      "fix": "Run: npm --workspace @cogedu/ava-api-types run build && npm --workspace @cogedu/ava-database-types run build && npm --workspace @cogedu/event-types run build"
    }
  ]
}